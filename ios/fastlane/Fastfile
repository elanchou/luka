default_platform(:ios)

platform :ios do
  before_all do
    ENV["PATH"] = "/Users/elanchou/Flutter/flutter/bin:/opt/homebrew/opt/ruby/bin:/opt/homebrew/bin:#{ENV['PATH']}"
    ENV["LANG"] = "en_US.UTF-8"
    ENV["LC_ALL"] = "en_US.UTF-8"

    @api_key = app_store_connect_api_key(
      key_id: "7V674759N8",
      issuer_id: "69a6de88-9503-47e3-e053-5b8c7c11a4d1",
      key_filepath: File.join(Dir.pwd, "AuthKey_7V674759N8.p8"),
    )
  end

  def prepare_ios_build
    sh("cd ../.. && flutter build ios --release --no-codesign")
  end

  def build_release_ipa
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
      },
      xcargs: "-allowProvisioningUpdates",
      export_xcargs: "-allowProvisioningUpdates",
      output_directory: "../build/ios",
      output_name: "Sault.ipa",
    )
  end

  desc "Build and upload to App Store"
  lane :release do
    increment_build_number(
      build_number: latest_testflight_build_number(api_key: @api_key) + 1,
      xcodeproj: "Runner.xcodeproj"
    )

    prepare_ios_build
    build_release_ipa

    upload_to_app_store(
      api_key: @api_key,
      skip_metadata: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false,
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    increment_build_number(
      build_number: latest_testflight_build_number(api_key: @api_key) + 1,
      xcodeproj: "Runner.xcodeproj"
    )

    prepare_ios_build
    build_release_ipa

    upload_to_testflight(
      api_key: @api_key,
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Submit the latest build for App Store review"
  lane :submit_release do
    upload_to_app_store(
      api_key: @api_key,
      force: true,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: false,
      phased_release: false,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: true,
        export_compliance_is_exempt: true,
      },
    )
  end
end
