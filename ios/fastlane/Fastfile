default_platform(:ios)

platform :ios do
  before_all do
    ENV["PATH"] = "/Users/elanchou/Flutter/flutter/bin:/opt/homebrew/opt/ruby/bin:/opt/homebrew/bin:#{ENV['PATH']}"
    ENV["LANG"] = "en_US.UTF-8"
    ENV["LC_ALL"] = "en_US.UTF-8"

    @api_key = app_store_connect_api_key(
      key_id: "7V674759N8",
      issuer_id: "69a6de88-9503-47e3-e053-5b8c7c11a4d1",
      key_filepath: File.join(Dir.pwd, "AuthKey_7V674759N8.p8"),
    )
  end

  def next_build_number
    remote_build_number = latest_testflight_build_number(api_key: @api_key).to_i
    local_build_number = get_build_number(xcodeproj: "Runner.xcodeproj").to_i

    [remote_build_number, local_build_number].max + 1
  rescue StandardError
    get_build_number(xcodeproj: "Runner.xcodeproj").to_i + 1
  end

  def prepare_ios_build
    sh("cd ../.. && flutter build ios --release --no-codesign")
  end

  def build_release_ipa
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
      },
      xcargs: "-allowProvisioningUpdates",
      export_xcargs: "-allowProvisioningUpdates",
      output_directory: "../build/ios",
      output_name: "Sault.ipa",
    )
  end

  def app_store_metadata_options
    options = {
      api_key: @api_key,
      skip_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false,
    }

    review_phone = ENV["APP_REVIEW_PHONE"].to_s.strip
    review_phone = "+86 15622346318" if review_phone.empty?
    unless review_phone.empty?
      options[:app_review_information] = {
        first_name: "Elan",
        last_name: "Chou",
        email_address: "lucidity95@gmail.com",
        phone_number: review_phone,
        notes: File.read(File.expand_path("../../docs/app-store/review-notes.md", __dir__)),
      }
    end

    options
  end

  desc "Upload App Store metadata only"
  lane :metadata do
    upload_to_app_store(
      **app_store_metadata_options,
      skip_binary_upload: true,
      submit_for_review: false,
    )
  end

  desc "Build and upload to App Store"
  lane :release do
    increment_build_number(
      build_number: next_build_number,
      xcodeproj: "Runner.xcodeproj"
    )

    prepare_ios_build
    build_release_ipa

    upload_to_app_store(
      **app_store_metadata_options,
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    increment_build_number(
      build_number: next_build_number,
      xcodeproj: "Runner.xcodeproj"
    )

    prepare_ios_build
    build_release_ipa

    upload_to_testflight(
      api_key: @api_key,
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Submit the latest build for App Store review"
  lane :submit_release do
    upload_to_app_store(
      **app_store_metadata_options,
      skip_binary_upload: true,
      submit_for_review: true,
      automatic_release: false,
      phased_release: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: true,
        export_compliance_is_exempt: true,
      },
    )
  end
end
